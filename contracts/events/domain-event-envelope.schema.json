{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/contracts/events/domain-event-envelope.schema.json",
  "title": "DomainEventEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "aggregate_id",
    "aggregate_version",
    "occurred_at",
    "correlation_id",
    "causation_id",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "aggregate_id": {
      "type": "string",
      "format": "uuid"
    },
    "aggregate_version": {
      "type": "integer",
      "minimum": 0
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "payload": {
      "type": "object"
    }
  }
}

