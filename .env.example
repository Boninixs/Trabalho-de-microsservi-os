COMPOSE_PROJECT_NAME=achados-e-perdidos
ENVIRONMENT=development
LOG_LEVEL=INFO

RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=app
RABBITMQ_EVENTS_EXCHANGE=domain.events
RABBITMQ_DEAD_LETTER_EXCHANGE=domain.events.dlx

AUTH_DB_NAME=auth_service
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres
AUTH_DB_PORT=5433

ITEM_DB_NAME=item_service
ITEM_DB_USER=postgres
ITEM_DB_PASSWORD=postgres
ITEM_DB_PORT=5434
ITEM_OUTBOX_PUBLISHER_ENABLED=true

MATCHING_DB_NAME=matching_service
MATCHING_DB_USER=postgres
MATCHING_DB_PASSWORD=postgres
MATCHING_DB_PORT=5435
MATCHING_EVENT_CONSUMER_ENABLED=true
MATCHING_OUTBOX_PUBLISHER_ENABLED=true

RECOVERY_DB_NAME=recovery_case_service
RECOVERY_DB_USER=postgres
RECOVERY_DB_PASSWORD=postgres
RECOVERY_DB_PORT=5436
RECOVERY_EVENT_CONSUMER_ENABLED=true
RECOVERY_OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_PUBLISH_POLL_INTERVAL_SECONDS=1
OUTBOX_PUBLISH_BATCH_SIZE=50
OUTBOX_PUBLISH_RETRY_DELAY_SECONDS=2
OUTBOX_PUBLISH_MAX_ATTEMPTS=10

GATEWAY_HTTP_PORT=8000
AUTH_SERVICE_HTTP_PORT=8001
ITEM_SERVICE_HTTP_PORT=8002
MATCHING_SERVICE_HTTP_PORT=8003
RECOVERY_CASE_SERVICE_HTTP_PORT=8004
GATEWAY_DOWNSTREAM_TIMEOUT_SECONDS=10
RABBITMQ_HTTP_PORT=15672
RABBITMQ_AMQP_PORT=5672

JWT_SECRET=change-me-in-phase-1
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
