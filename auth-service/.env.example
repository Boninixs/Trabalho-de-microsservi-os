SERVICE_NAME=auth-service
SERVICE_VERSION=0.1.0
SERVICE_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/auth_service
DATABASE_ECHO=false
RABBITMQ_URL=amqp://app:app@localhost:5672/
RABBITMQ_EVENTS_EXCHANGE=domain.events
RABBITMQ_DEAD_LETTER_EXCHANGE=domain.events.dlx
JWT_SECRET=change-me-in-phase-1
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
